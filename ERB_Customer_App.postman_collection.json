{
  "info": {
    "name": "ERB Customer Mobile App",
    "_postman_id": "erb-customer-app-v1",
    "description": "All endpoints used by the ERB Roastery customer mobile application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.patriacoffeebeans.com", "type": "string" },
    { "key": "token",   "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/auth/register" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ahmed Said\",\n  \"email\": \"ahmed@example.com\",\n  \"phone\": \"01012345678\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/auth/login" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"01012345678\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Send Phone Verification",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/auth/send-verification" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"01012345678\"\n}" }
          }
        },
        {
          "name": "Verify Phone",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/auth/verify-phone" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"01012345678\",\n  \"code\": \"1234\",\n  \"fcmToken\": \"device_fcm_token_here\"\n}" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/auth/forgot-password" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"01012345678\"\n}" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/auth/reset-password" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"01012345678\",\n  \"code\": \"1234\",\n  \"newPassword\": \"newPassword123\"\n}" }
          }
        },
        {
          "name": "Google OAuth Login",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/auth/oauth/login" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idToken\": \"google_id_token_here\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/auth/change-password" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"oldPassword123\",\n  \"newPassword\": \"newPassword456\"\n}" }
          }
        }
      ]
    },
    {
      "name": "2. Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/users/profile" }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/users/profile" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ahmed Said\",\n  \"email\": \"ahmed@example.com\"\n}" }
          }
        },
        {
          "name": "Update Password",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/users/password" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"old123\",\n  \"newPassword\": \"new456\"\n}" }
          }
        },
        {
          "name": "Get Loyalty Points",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/users/loyalty" }
          }
        },
        {
          "name": "Loyalty Checkout Preview",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/users/loyalty/checkout-preview" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"pointsToRedeem\": 100,\n  \"orderTotal\": 250\n}" }
          }
        }
      ]
    },
    {
      "name": "3. Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/products?category=&search=&page=1&limit=20" }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/products/:id",
              "variable": [{ "key": "id", "value": "PRODUCT_ID_HERE" }]
            }
          }
        },
        {
          "name": "Rate Product",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/products/:id/rate",
              "variable": [{ "key": "id", "value": "PRODUCT_ID_HERE" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"rating\": 5\n}" }
          }
        }
      ]
    },
    {
      "name": "4. Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/cart" } }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/cart/add" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"PRODUCT_ID\",\n  \"quantity\": 2,\n  \"customization\": {\n    \"roastLevel\": \"Medium\",\n    \"grindType\": \"Fine\"\n  },\n  \"selectedVariants\": [],\n  \"selectedExtras\": [],\n  \"notes\": \"\"\n}" }
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/cart/update/:itemId",
              "variable": [{ "key": "itemId", "value": "ITEM_ID_HERE" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 3\n}" }
          }
        },
        {
          "name": "Get Cart Item",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/cart/item/:itemId",
              "variable": [{ "key": "itemId", "value": "ITEM_ID_HERE" }]
            }
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/cart/remove/:itemId",
              "variable": [{ "key": "itemId", "value": "ITEM_ID_HERE" }]
            }
          }
        },
        {
          "name": "Clear Cart",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/cart/clear" } }
        },
        {
          "name": "Cart to Order Items",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/cart/to-order-items" } }
        }
      ]
    },
    {
      "name": "5. Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/orders" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"orderType\": \"Delivery\",\n  \"items\": [\n    {\n      \"product\": \"PRODUCT_ID\",\n      \"name\": \"Ethiopian Coffee\",\n      \"quantity\": 2,\n      \"price\": 120,\n      \"customization\": { \"roastLevel\": \"Medium\", \"grindType\": \"Fine\" }\n    }\n  ],\n  \"customer\": {\n    \"name\": \"Ahmed Said\",\n    \"phone\": \"01012345678\",\n    \"address\": \"123 Main St, Alexandria\",\n    \"region\": \"ZONE_ID\",\n    \"location\": { \"lat\": 31.2001, \"lng\": 29.9187 }\n  },\n  \"summary\": {\n    \"subtotal\": 240,\n    \"deliveryFee\": 25,\n    \"total\": 265\n  },\n  \"payment\": { \"method\": \"Cash\" },\n  \"notes\": \"\"\n}" }
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/orders/my-orders?page=1&limit=10" }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/orders/:id",
              "variable": [{ "key": "id", "value": "ORDER_ID_HERE" }]
            }
          }
        },
        {
          "name": "Reorder",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/orders/reorder/:id",
              "variable": [{ "key": "id", "value": "ORDER_ID_HERE" }]
            }
          }
        },
        {
          "name": "Live Tracking",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/v2/orders/:orderId/tracking",
              "variable": [{ "key": "orderId", "value": "ORDER_ID_HERE" }]
            }
          }
        },
        {
          "name": "Save Customer Location to Order",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/api/v2/orders/:orderId/customer-location",
              "variable": [{ "key": "orderId", "value": "ORDER_ID_HERE" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"lat\": 31.2001,\n  \"lng\": 29.9187\n}" }
          }
        }
      ]
    },
    {
      "name": "6. Addresses",
      "item": [
        {
          "name": "Get Addresses",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v2/addresses" } }
        },
        {
          "name": "Add Address",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v2/addresses" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"label\": \"Home\",\n  \"address\": \"123 Main St, Alexandria\",\n  \"lat\": 31.2001,\n  \"lng\": 29.9187,\n  \"isDefault\": true\n}" }
          }
        },
        {
          "name": "Update Address",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/v2/addresses/:addressId",
              "variable": [{ "key": "addressId", "value": "ADDRESS_ID_HERE" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"label\": \"Work\",\n  \"address\": \"456 Office Rd\",\n  \"lat\": 31.2100,\n  \"lng\": 29.9200\n}" }
          }
        },
        {
          "name": "Delete Address",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v2/addresses/:addressId",
              "variable": [{ "key": "addressId", "value": "ADDRESS_ID_HERE" }]
            }
          }
        },
        {
          "name": "Set Default Address",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/api/users/addresses/:id/set-default",
              "variable": [{ "key": "id", "value": "ADDRESS_ID_HERE" }]
            }
          }
        }
      ]
    },
    {
      "name": "7. Notifications",
      "item": [
        {
          "name": "Register FCM Device Token",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v2/notifications/device" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fcmToken\": \"device_fcm_token_here\",\n  \"platform\": \"android\"\n}" }
          }
        },
        {
          "name": "Unregister FCM Device Token",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v2/notifications/device" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fcmToken\": \"device_fcm_token_here\"\n}" }
          }
        },
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v2/notifications?page=1&limit=20" }
          }
        },
        {
          "name": "Get Unread Count",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v2/notifications/unread-count" }
          }
        },
        {
          "name": "Mark All as Read",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/api/v2/notifications/read-all" }
          }
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/api/v2/notifications/:id/read",
              "variable": [{ "key": "id", "value": "NOTIFICATION_ID_HERE" }]
            }
          }
        }
      ]
    },
    {
      "name": "8. Favorites",
      "item": [
        {
          "name": "Get Favorites",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/users/favorites" } }
        },
        {
          "name": "Add to Favorites",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/users/favorites/:productId",
              "variable": [{ "key": "productId", "value": "PRODUCT_ID_HERE" }]
            }
          }
        },
        {
          "name": "Remove from Favorites",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/users/favorites/:productId",
              "variable": [{ "key": "productId", "value": "PRODUCT_ID_HERE" }]
            }
          }
        }
      ]
    },
    {
      "name": "9. Offers & Coupons",
      "item": [
        {
          "name": "Get Active Offers",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/offers/active" }
          }
        },
        {
          "name": "Validate Coupon",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/offers/validate" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"SAVE20\",\n  \"orderTotal\": 300\n}" }
          }
        }
      ]
    },
    {
      "name": "10. Search",
      "item": [
        {
          "name": "Log Search Query",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v2/customer-search/log" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"ethiopian coffee\"\n}" }
          }
        },
        {
          "name": "Get Last Search",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v2/customer-search/last" }
          }
        },
        {
          "name": "Get Trending Searches",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/v2/customer-search/trending" }
          }
        },
        {
          "name": "Get Search History",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v2/customer-search/history" }
          }
        },
        {
          "name": "Clear Search History",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v2/customer-search/history" }
          }
        }
      ]
    },
    {
      "name": "11. Reviews",
      "item": [
        {
          "name": "Submit Review",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/reviews" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"orderId\": \"ORDER_ID_HERE\",\n  \"rating\": 5,\n  \"comment\": \"Excellent coffee!\"\n}" }
          }
        },
        {
          "name": "Get Review for Order",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/reviews/order/:orderId",
              "variable": [{ "key": "orderId", "value": "ORDER_ID_HERE" }]
            }
          }
        }
      ]
    },
    {
      "name": "12. Zones",
      "item": [
        {
          "name": "Get All Delivery Zones",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/v2/zones" }
          }
        },
        {
          "name": "Zone Lookup by Coordinates",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/v2/zones/lookup?lat=31.2001&lng=29.9187" }
          }
        }
      ]
    }
  ]
}
